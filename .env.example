# Copy this file to .env and fill in your values.
# Hugo reads HUGO_PARAMS_* variables and merges them into .Site.Params.*

# Firebase project config (not secret — safe to expose to the browser)
HUGO_PARAMS_FIREBASE_API_KEY=
HUGO_PARAMS_FIREBASE_AUTH_DOMAIN=
HUGO_PARAMS_FIREBASE_PROJECT_ID=
HUGO_PARAMS_FIREBASE_STORAGE_BUCKET=
HUGO_PARAMS_FIREBASE_MESSAGING_SENDER_ID=
HUGO_PARAMS_FIREBASE_APP_ID=

# Stripe publishable key (not secret — safe for the browser)
HUGO_PARAMS_STRIPE_PUBLISHABLEKEY=

# Stripe price IDs — populated once products are set up
HUGO_PARAMS_STRIPE_PRICE_BASIC=
HUGO_PARAMS_STRIPE_PRICE_PRO=
HUGO_PARAMS_STRIPE_PRICE_BASICANNUAL=
HUGO_PARAMS_STRIPE_PRICE_PROANNUAL=

# Backend API base URL
HUGO_PARAMS_BACKENDURL=http://localhost:8080

# Static data sources (GitHub-first, GCS fallback)
HUGO_PARAMS_GCS_DATA_BUCKET=slab-cracker-data
HUGO_PARAMS_GITHUB_DATA_REPO=FutureGadgetCollections/slab-cracker-data
